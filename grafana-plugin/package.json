    "@grafana/ui":      "^10.0.0",
    "react":            "^18.0.0",
    "react-dom":        "^18.0.0"
  },
  "devDependencies": {
    "@grafana/toolkit": "^10.0.0",
    "@types/react":     "^18.0.0",
    "typescript":       "^5.0.0"
  }
}
