# ═══════════════════════════════════════════════════════════════════════════════
# CloudSense Environment Configuration
# Copy to .env and fill in your cloud credentials
# ═══════════════════════════════════════════════════════════════════════════════

# ── App ────────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production-generate-a-64-char-random-string

# ── ClickHouse ─────────────────────────────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=cloudsense
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DATABASE=cloudsense
POSTGRES_USER=cloudsense
POSTGRES_PASSWORD=cloudsense

# ── Kafka ──────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379

# ── AWS Credentials ────────────────────────────────────────────────────────────
# Requires: ce:GetCostAndUsage, ec2:DescribeInstances, rds:DescribeDBInstances
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# ── Azure Credentials ──────────────────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── GCP Credentials ────────────────────────────────────────────────────────────
# Path to service account JSON key file
GCP_PROJECT_ID=
GCP_CREDENTIALS_JSON=

# ── LLM / Agent Configuration ──────────────────────────────────────────────────
# Choose LLM provider: anthropic or openai
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# LangSmith (optional — for LLM observability)
ENABLE_LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=cloudsense

# ── OPA Policy Engine ──────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181/v1/data/cloudsense

# ── Slack Integration ──────────────────────────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=

# ── Observability ──────────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
