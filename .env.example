# ─────────────────────────────────────────────────────────────────────────────
# CloudSense — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=development           # development | staging | production
DEBUG=false
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── ClickHouse (OLAP billing store) ───────────────────────────────────────────
CLICKHOUSE_HOST=localhost
CLICKHOUSE_PORT=8123
CLICKHOUSE_DATABASE=cloudsense
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── PostgreSQL (metadata, config, users) ─────────────────────────────────────
POSTGRES_DSN=postgresql://cloudsense:cloudsense@localhost:5432/cloudsense

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_AGENT_MEMORY_TTL=3600

# ── Kafka ────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=cloudsense-agents
KAFKA_BILLING_TOPIC=cloudsense.billing.events
KAFKA_ANOMALY_TOPIC=cloudsense.anomalies

# ── LLM Backbone ─────────────────────────────────────────────────────────────
LLM_PROVIDER=anthropic            # anthropic | openai | ollama
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-20250514
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3

# ── AWS Connector ─────────────────────────────────────────────────────────────
# Prefer IAM roles in production. Static keys for local dev only.
# AWS_ACCESS_KEY_ID=AKIA...
# AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# AWS_ROLE_ARN=arn:aws:iam::123456789012:role/CloudSenseReadOnly

# ── Azure Connector ───────────────────────────────────────────────────────────
# AZURE_TENANT_ID=...
# AZURE_CLIENT_ID=...
# AZURE_CLIENT_SECRET=...
# AZURE_SUBSCRIPTION_ID=...

# ── GCP Connector ─────────────────────────────────────────────────────────────
# GCP_PROJECT_ID=my-project
# GCP_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# GCP_BILLING_DATASET=billing_export

# ── Policy Engine ─────────────────────────────────────────────────────────────
OPA_URL=http://localhost:8181

# ── Observability ─────────────────────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=ls__...
AUTO_APPROVE_NON_PRODUCTION=true
ROLLBACK_WINDOW_DAYS=7
