# CloudSense — Environment Configuration
# Copy this file to .env and fill in your values
# Never commit .env to version control

# ── General ────────────────────────────────────────────────────
ENV=development
SECRET_KEY=change-me-to-a-random-32-char-string-in-production

# ── Database passwords ──────────────────────────────────────────
CLICKHOUSE_PASSWORD=dev_password_change_me
POSTGRES_PASSWORD=dev_password_change_me
REDIS_PASSWORD=dev_password_change_me
GRAFANA_PASSWORD=admin

# ── AWS Connector ───────────────────────────────────────────────
AWS_ACCOUNT_ID=
AWS_ACCOUNT_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional: cross-account role for read-only access
AWS_ROLE_ARN=

# ── Azure Connector ─────────────────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── GCP Connector ───────────────────────────────────────────────
GCP_BILLING_ACCOUNT_ID=
GCP_BQ_DATASET=your-project.billing_dataset
# Path to service account key JSON (or use Workload Identity in GKE)
GOOGLE_APPLICATION_CREDENTIALS=
